{
  "name": "nexoged-assinador",
  "version": "0.1.3",
  "description": "Ponte local de assinatura A1/A3 para NexoGED",
  "main": "main.cjs",
  "private": true,
  "scripts": {
    "start": "electron .",
    "package:win": "electron-packager . NexoGED-Assinador --platform=win32 --arch=x64 --out=dist --overwrite --icon=assets/icon.ico --ignore=^/dist",
    "package:mac": "electron-packager . NexoGED-Assinador --platform=darwin --arch=x64 --out=dist --overwrite --icon=assets/icon.icns --ignore=^/dist",
    "package:linux": "electron-packager . NexoGED-Assinador --platform=linux --arch=x64 --out=dist --overwrite --ignore=^/dist"
  },
  "dependencies": {
    "node-forge": "^1.3.1",
    "pkcs11js": "^2.1.6"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "@electron/packager": "^18.3.5"
  }
}
